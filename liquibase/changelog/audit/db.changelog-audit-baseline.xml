<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:pro="http://www.liquibase.org/xml/ns/pro" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-latest.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet author="IntkhabShaikh" id="1748426430288-1">
        <createTable tableName="project_other_cost_planned_audit">
            <column defaultValueComputed="gen_random_uuid()" name="audit_id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="project_other_cost_planned_audit_pkey"/>
            </column>
            <column name="project_other_cost_planned_id" type="UUID"/>
            <column name="external_id" type="VARCHAR(50)"/>
            <column name="project_other_cost_planned_amount" type="numeric(18, 2)"/>
            <column name="project_other_cost_planned_remark" type="VARCHAR(255)"/>
            <column name="other_cost_item_id" type="UUID"/>
            <column name="project_id" type="UUID"/>
            <column name="is_active" type="BOOLEAN"/>
            <column name="created_by" type="UUID"/>
            <column name="created_on" type="TIMESTAMP WITHOUT TIME ZONE"/>
            <column name="updated_by" type="UUID"/>
            <column name="updated_on" type="TIMESTAMP WITHOUT TIME ZONE"/>
            <column name="audit_type" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column defaultValueComputed="now()" name="audit_timestamp" type="TIMESTAMP WITHOUT TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="audit_by" type="UUID"/>
            <column defaultValue="system" name="source_app" type="VARCHAR(50)"/>
        </createTable>
    </changeSet>
    <changeSet author="IntkhabShaikh" id="1748426430288-2">
        <createTable tableName="project_other_cost_actual_audit">
            <column defaultValueComputed="gen_random_uuid()" name="audit_id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="project_other_cost_actual_audit_pkey"/>
            </column>
            <column name="project_other_cost_actual_id" type="UUID"/>
            <column name="external_id" type="VARCHAR(50)"/>
            <column name="project_other_cost_actual_amount" type="numeric(18, 2)"/>
            <column name="project_other_cost_actual_remark" type="VARCHAR(500)"/>
            <column name="project_other_cost_planned_id" type="UUID"/>
            <column name="is_active" type="BOOLEAN"/>
            <column name="created_by" type="UUID"/>
            <column name="created_on" type="TIMESTAMP WITHOUT TIME ZONE"/>
            <column name="updated_by" type="UUID"/>
            <column name="updated_on" type="TIMESTAMP WITHOUT TIME ZONE"/>
            <column name="audit_type" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column defaultValueComputed="now()" name="audit_timestamp" type="TIMESTAMP WITHOUT TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="audit_by" type="UUID"/>
            <column defaultValue="system" name="source_app" type="VARCHAR(50)"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
